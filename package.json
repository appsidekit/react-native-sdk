{
  "name": "@sidekit/react-native",
  "version": "1.0.0",
  "description": "SideKit React Native SDK for version gating and analytics",
  "main": "lib/commonjs/index",
  "module": "lib/module/index",
  "types": "lib/typescript/index.d.ts",
  "react-native": "src/index",
  "source": "src/index",
  "files": [
    "src",
    "lib",
    "!**/__tests__",
    "!**/__fixtures__",
    "!**/__mocks__"
  ],
  "scripts": {
    "test": "jest --passWithNoTests",
    "test:coverage": "jest --coverage",
    "typescript": "tsc --noEmit",
    "lint": "eslint \"src/**/*.{ts,tsx}\"",
    "prepare": "bob build",
    "clean": "rm -rf lib"
  },
  "keywords": [
    "react-native",
    "sidekit",
    "version-gating",
    "analytics",
    "update-management",
    "app-updates",
    "forced-updates",
    "version-management",
    "expo",
    "ios",
    "android",
    "cross-platform",
    "typescript",
    "react-native-component"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/appsidekit/react-native-sdk.git"
  },
  "author": "SideKit",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/appsidekit/react-native-sdk/issues"
  },
  "homepage": "https://github.com/appsidekit/react-native-sdk#readme",
  "publishConfig": {
    "registry": "https://registry.npmjs.org/"
  },
  "peerDependencies": {
    "@react-native-async-storage/async-storage": "*",
    "expo": "*",
    "expo-application": "*",
    "expo-device": "*",
    "expo-linear-gradient": "*",
    "react": "*",
    "react-native": "*"
  },
  "peerDependenciesMeta": {
    "@react-native-async-storage/async-storage": {
      "optional": true
    }
  },
  "devDependencies": {
    "@react-native-async-storage/async-storage": "^1.21.0",
    "@testing-library/react-native": "^12.4.0",
    "@types/jest": "^29.5.0",
    "@types/react": "^18.2.0",
    "@types/react-native": "^0.73.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.50.0",
    "expo": "^54.0.32",
    "expo-application": "^6.0.0",
    "expo-device": "^7.0.0",
    "expo-linear-gradient": "^14.0.0",
    "jest": "^29.7.0",
    "react": "^18.3.1",
    "react-native": "^0.76.5",
    "react-native-builder-bob": "^0.23.0",
    "react-test-renderer": "^18.3.1",
    "ts-jest": "^29.1.0",
    "typescript": "^5.3.0"
  },
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "targets": [
      "commonjs",
      "module",
      [
        "typescript",
        {
          "project": "tsconfig.build.json"
        }
      ]
    ]
  }
}
